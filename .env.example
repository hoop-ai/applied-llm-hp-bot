# OpenRouter API key. Get one free at https://openrouter.ai/
OPENROUTER_API_KEY=

# Model id. Any OpenRouter-supported model. Free options that tend to be less
# rate-limited than the headline 70B+ tiers:
#   z-ai/glm-4.5-air:free          (default — capable, low traffic)
#   openai/gpt-oss-20b:free
#   nvidia/nemotron-nano-9b-v2:free
#   qwen/qwen3-next-80b-a3b-instruct:free
#   meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

# Stage-A similarity threshold (0..1). If top-1 question-match >= this, return cached answer without LLM call.
THRESHOLD_A=0.85

# Stage-B top-K passages to retrieve as context.
TOP_K_B=5

# How many prior turns to keep in conversation memory.
MEMORY_TURNS=5
